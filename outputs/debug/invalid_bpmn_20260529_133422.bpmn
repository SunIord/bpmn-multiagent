<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI">
  <process id="Process_1" isExecutable="false">
    <startEvent id="startEvent_1" name="interested party submits application, solemn declaration and supporting documents"/>
    <exclusiveGateway id="exclusiveGateway_1" name="no omissions identified?">
      <sequenceFlow id="flow_3" sourceRef="startEvent_1" targetRef="exclusiveGateway_1"/>
      <sequenceFlow id="flow_4" name="sim" sourceRef="exclusiveGateway_1" targetRef="endEvent_1"/>
    </exclusiveGateway>
    <exclusiveGateway id="exclusiveGateway_2" name="omissions identified?">
      <sequenceFlow id="flow_5" name="não" sourceRef="startEvent_1" targetRef="exclusiveGateway_2"/>
      <sequenceFlow id="flow_6" targetRef="endEvent_2"/>
    </exclusiveGateway> <!-- Fechamento errado removido e acrescentado abaixo -->
    <endEvent id="endEvent_1" name="process terminated">
      <incoming flowRef="flow_4"/>
    </endEvent>
    <endEvent id="endEvent_2" name="applicant receives printed driving license in person">
      <incoming flowRef="flow_6"/>
    </endEvent>
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">
      <!-- Aqui estavam os shapes de exclusiveGateway_2, mas foi movido para o final -->
      ...
      <bpmndi:BPMNShape id="exclusiveGateway_2_di" bpmnElement="exclusiveGateway_2">
        <dc:Bounds x="400" y="215" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endEvent_2_di" bpmnElement="endEvent_2">
        <dc:Bounds x="700" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>